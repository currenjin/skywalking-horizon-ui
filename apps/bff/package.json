{
  "name": "@skywalking-horizon-ui/bff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server.js --packages=external",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.cjs,.mjs --fix --ignore-path ../../.gitignore",
    "test:unit": "vitest --root src/"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/static": "^8.0.2",
    "@skywalking-horizon-ui/api-client": "workspace:*",
    "argon2": "^0.41.1",
    "chokidar": "^4.0.1",
    "fastify": "^5.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vitest": "^2.1.4"
  }
}
