{
  "id": "general",
  "title": "General service",
  "description": "Overview of services on the General layer with the Kubernetes service-count cross-referenced.",
  "widgets": [
    {
      "id": "g_count",
      "title": "Active services",
      "tip": "Number of services reporting on this layer.",
      "layer": "GENERAL",
      "type": "service-count",
      "span": 3,
      "rowSpan": 1
    },
    {
      "id": "g_rpm",
      "title": "Throughput",
      "tip": "Layer-wide requests per minute.",
      "layer": "GENERAL",
      "type": "metric",
      "mqe": "service_cpm",
      "unit": "rpm",
      "aggregation": "sum",
      "span": 3,
      "rowSpan": 1
    },
    {
      "id": "g_p99",
      "title": "P99 latency",
      "tip": "99th-percentile response time across the layer.",
      "layer": "GENERAL",
      "type": "metric",
      "mqe": "service_percentile{p='99'}",
      "unit": "ms",
      "aggregation": "avg",
      "span": 3,
      "rowSpan": 1
    },
    {
      "id": "g_err",
      "title": "Error rate",
      "tip": "100 − SLA. Higher = worse.",
      "layer": "GENERAL",
      "type": "metric",
      "mqe": "100 - service_sla/100",
      "unit": "%",
      "aggregation": "avg",
      "span": 3,
      "rowSpan": 1
    },
    {
      "id": "k8s_count",
      "title": "K8s services",
      "tip": "Services reporting through the K8s service layer.",
      "layer": "K8S_SERVICE",
      "type": "service-count",
      "span": 3,
      "rowSpan": 1
    },
    {
      "id": "k8s_p99",
      "title": "K8s P99",
      "tip": "99th-percentile latency for K8s-routed traffic.",
      "layer": "K8S_SERVICE",
      "type": "metric",
      "mqe": "k8s_service_resp_time_percentile{p='99'}",
      "unit": "ms",
      "aggregation": "avg",
      "span": 3,
      "rowSpan": 1
    },
    {
      "id": "g_topo",
      "title": "General service topology",
      "tip": "Live service map for GENERAL — same renderer as the per-layer Topology tab.",
      "layer": "GENERAL",
      "type": "topology",
      "span": 12,
      "rowSpan": 4
    }
  ]
}
